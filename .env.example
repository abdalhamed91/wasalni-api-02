# متغيّرات بيئة وصلني — انسخها في إعدادات Railway (Variables)
# لا ترفع ملف .env الحقيقي إلى GitHub أبدًا

# منفذ الخادم (Railway يضبطه تلقائيًّا — اتركه فارغًا)
PORT=

# مفتاح توقيع الجلسات (JWT) — استبدله بسلسلة عشوائية طويلة وسرّية
JWT_SECRET=ضع-هنا-سلسلة-عشوائية-طويلة-جدا

# كلمة مرور لوحة الإدارة — غيّرها لكلمة قوية
ADMIN_SECRET=كلمة-مرور-إدارة-قوية

# تقييد مصادر CORS (قائمة مفصولة بفواصل) — اتركه فارغًا للسماح للجميع (تطوير)
# مثال للإنتاج: https://wasalni-api-production.up.railway.app
CORS_ORIGIN=

# مسار قاعدة البيانات الدائمة (يشير إلى الـVolume)
DB_PATH=/data/wasalni.db

# وضع الإنتاج (يُعطّل الرمز السرّي التجريبي 0000)
NODE_ENV=production

# قاعدة بيانات PostgreSQL للإنتاج (Neon/Supabase/Railway)
# عند وجوده يُستخدم PostgreSQL تلقائيًّا، وإلا SQLite للتطوير
DATABASE_URL=postgresql://user:pass@host/dbname

# ===== مزوّد SMS (المرحلة 2) =====
# فعّل واحدًا فقط بوضع مفاتيحه. بلا مفاتيح = وضع تطوير (رمز يظهر في الاستجابة)

# خيار 1: Unifonic (موصى به سعوديًّا) — من لوحة تحكم Unifonic
UNIFONIC_APPSID=
UNIFONIC_SENDER_ID=Wasalni

# خيار 2: Twilio (عالمي) — من لوحة تحكم Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
